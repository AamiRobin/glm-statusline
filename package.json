{
  "name": "glm-statusline",
  "version": "1.0.0",
  "description": "A beautiful statusline for Claude Code that displays real-time quota, context usage, and reset information from the GLM API",
  "main": "statusline-command.js",
  "bin": {
    "glm-statusline": "./statusline-command.js",
    "install-glm-statusline": "./install.js"
  },
  "scripts": {
    "test": "echo '{\"context_window\":{\"used_percentage\":45},\"workspace\":{\"current_dir\":\"/test/project\"}}' | node statusline-command.js",
    "postinstall": "node install.js"
  },
  "keywords": [
    "claude-code",
    "statusline",
    "glm-api",
    "quota-monitor",
    "cli",
    "developer-tools"
  ],
  "author": "AmiRobin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AamiRobin/glm-statusline.git"
  },
  "bugs": {
    "url": "https://github.com/AamiRobin/glm-statusline/issues"
  },
  "homepage": "https://github.com/AamiRobin/glm-statusline#readme",
  "engines": {
    "node": ">=14.0.0"
  }
}
